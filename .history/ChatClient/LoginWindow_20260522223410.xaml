<Window x:Class="ChatClient.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Nhập Group Chat" Height="280" Width="340"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6">
    <StackPanel Margin="30" VerticalAlignment="Center">

        <!-- Server address -->
        <TextBlock Text="Địa chỉ server:" Margin="0,0,0,6"
                   FontWeight="Medium" Foreground="#111827"/>
        <TextBox x:Name="ServerInputBox" Height="36" Padding="10,8"
                 FontSize="14" Margin="0,0,0,16"
                 Text="0.tcp.ap.ngrok.io:24100"/>

        <!-- Username -->
        <TextBlock Text="Tên của bạn:" Margin="0,0,0,6"
                   FontWeight="Medium" Foreground="#111827"/>
        <TextBox x:Name="NameInputBox" Height="36" Padding="10,8"
                 FontSize="14" Margin="0,0,0,24"/>

        <!-- Join button -->
        <Button Content="Vào phòng chat" Height="40"
                Background="#2563EB" Foreground="White"
                FontWeight="Bold" Cursor="Hand" BorderThickness="0"
                Click="JoinButton_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>

    </StackPanel>
</Window>