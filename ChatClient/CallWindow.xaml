<Window x:Class="ChatClient.CallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Call" Height="500" Width="350"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">
    
    <Border CornerRadius="12" Background="#111111" BorderThickness="1" BorderBrush="#333333">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <Button Content="✕" Width="24" Height="24" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Click="EndCall_Click"/>
            </StackPanel>
            
            <!-- Avatar / Video Area -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="120" Height="120" CornerRadius="60" Background="#333333" Margin="0,0,0,20">
                    <TextBlock Text="👥" FontSize="60" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="CallStatusText" Text="Đang gọi nhóm..." FontSize="20" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8" FontWeight="SemiBold"/>
                <TextBlock x:Name="TimerText" Text="00:00" FontSize="16" Foreground="#AAAAAA" HorizontalAlignment="Center" Visibility="Collapsed"/>
            </StackPanel>
            
            <!-- Action Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Width="50" Height="50" Margin="10" Background="#333333" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                <TextBlock Text="🎤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Width="60" Height="60" Margin="10" Background="#FF3B30" BorderThickness="0" Cursor="Hand" Click="EndCall_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="30">
                                <TextBlock Text="📞" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" RenderTransformOrigin="0.5, 0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="135"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Width="50" Height="50" Margin="10" Background="#333333" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                <TextBlock Text="🎥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
