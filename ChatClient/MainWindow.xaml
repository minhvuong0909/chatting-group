<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChatClient"
        Title="Group Chat" Height="650" Width="550"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.Resources>
        <local:Base64ToImageConverter x:Key="Base64Converter"/>
        
        <!-- Style cho bubble tin nhắn -->
        <Style x:Key="MessageBubbleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MaxWidth" Value="320"/>
        </Style>

        <!-- Style cho nút icon -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#0084FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho nút Gửi -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0084FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0073E6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005BB5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A0CFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplate cho từng tin nhắn -->
        <DataTemplate x:Key="MessageItemTemplate">
            <Grid Margin="0,4,0,4">
                <StackPanel x:Name="MessageContainer" MaxWidth="350" HorizontalAlignment="Left">
                    <TextBlock x:Name="SenderNameBlock" Text="{Binding SenderName}" FontSize="12" Foreground="#65676B" Margin="8,0,0,3" HorizontalAlignment="Left"/>

                    <Border x:Name="BubbleBorder" Padding="12,8" Background="#E4E6EB" CornerRadius="18,18,18,4">
                        <StackPanel>
                            <!-- Text Content -->
                            <TextBlock x:Name="MessageText" Text="{Binding Content}" FontSize="15" Foreground="Black" TextWrapping="Wrap" LineHeight="20" Visibility="Visible"/>
                            
                            <!-- Image Content -->
                            <Grid>
                                <Image x:Name="MessageImage" Source="{Binding DisplayImageBase64, Converter={StaticResource Base64Converter}}" MaxWidth="250" MaxHeight="250" Stretch="Uniform" Visibility="Collapsed" Margin="0,4,0,0" RenderOptions.BitmapScalingMode="HighQuality" Cursor="Hand" MouseLeftButtonDown="MessageImage_MouseLeftButtonDown" Tag="{Binding}"/>
                                <Border x:Name="PlayIconOverlay" Visibility="Collapsed" Background="#80000000" Width="40" Height="40" CornerRadius="20" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock Text="▶" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                </Border>
                            </Grid>
                            
                            <!-- File Content -->
                            <Button x:Name="FileButton" Visibility="Collapsed" Background="#F0F2F5" BorderThickness="1" BorderBrush="#D1D5DB" Padding="8" Cursor="Hand" Click="FileButton_Click" Tag="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📁" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding FileName}" FontSize="14" Foreground="#0084FF" TextDecorations="Underline" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <!-- Call Content -->
                            <Button x:Name="CallJoinButton" Visibility="Collapsed" Background="#28a745" Foreground="White" BorderThickness="0" Padding="15,8" Margin="0,6,0,0" Cursor="Hand" Click="JoinCallButton_Click" Tag="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="15" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="📞" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Tham gia" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="TimeBlock" Text="{Binding Timestamp, StringFormat=HH:mm}" FontSize="10" Foreground="#BEC2C9" Margin="8,3,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>

            <DataTemplate.Triggers>
                <!-- My Message Alignment -->
                <DataTrigger Binding="{Binding IsMyMessage}" Value="True">
                    <Setter TargetName="MessageContainer" Property="HorizontalAlignment" Value="Right"/>
                    <Setter TargetName="BubbleBorder" Property="Background" Value="#0084FF"/>
                    <Setter TargetName="MessageText" Property="Foreground" Value="White"/>
                    <Setter TargetName="BubbleBorder" Property="CornerRadius" Value="18,18,4,18"/>
                    <Setter TargetName="TimeBlock" Property="HorizontalAlignment" Value="Right"/>
                    <Setter TargetName="SenderNameBlock" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                
                <!-- Type: Image -->
                <DataTrigger Binding="{Binding IsImage}" Value="True">
                    <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="MessageImage" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="BubbleBorder" Property="Background" Value="Transparent"/>
                    <Setter TargetName="BubbleBorder" Property="Padding" Value="0"/>
                </DataTrigger>

                <!-- Type: Sticker -->
                <DataTrigger Binding="{Binding IsSticker}" Value="True">
                    <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="MessageImage" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="MessageImage" Property="MaxWidth" Value="120"/>
                    <Setter TargetName="MessageImage" Property="MaxHeight" Value="120"/>
                    <Setter TargetName="BubbleBorder" Property="Background" Value="Transparent"/>
                    <Setter TargetName="BubbleBorder" Property="Padding" Value="0"/>
                </DataTrigger>

                <!-- Type: File -->
                <DataTrigger Binding="{Binding IsFile}" Value="True">
                    <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="FileButton" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                
                <!-- Type: Call -->
                <DataTrigger Binding="{Binding IsCall}" Value="True">
                    <Setter TargetName="CallJoinButton" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsFile}" Value="True"/>
                        <Condition Binding="{Binding IsMyMessage}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="BubbleBorder" Property="Background" Value="Transparent"/>
                    <Setter TargetName="BubbleBorder" Property="Padding" Value="0"/>
                </MultiDataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <!-- Layout chính -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/> <!-- Header -->
            <RowDefinition Height="*"/>  <!-- Chat area -->
            <RowDefinition Height="Auto"/> <!-- Preview & Input area -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Border Width="40" Height="40" CornerRadius="20" Background="#E4E6EB" Margin="0,0,12,0">
                        <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Nhóm Đồ Án" FontSize="16" FontWeight="Bold" Foreground="#050505"/>
                        <TextBlock x:Name="CurrentUserLabel" Text="Đang đăng nhập dưới tên: Anh" FontSize="12" Foreground="#65676B"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button x:Name="VoiceCallButton" Content="📞" ToolTip="Gọi thoại" Style="{StaticResource IconButtonStyle}" Margin="0,0,8,0" Click="VoiceCallButton_Click"/>
                    <Button x:Name="VideoCallButton" Content="🎥" ToolTip="Gọi video" Style="{StaticResource IconButtonStyle}" Click="VideoCallButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chat Area -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="16,16,16,16" Background="#F0F2F5">
            <ItemsControl x:Name="MessagesItemsControl" ItemsSource="{Binding Messages}" ItemTemplate="{StaticResource MessageItemTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input & Preview Area -->
        <StackPanel Grid.Row="2" Background="White" Margin="0,0,0,8">
            
            <!-- Preview Area -->
            <Border x:Name="PreviewArea" Visibility="Collapsed" Background="#F0F2F5" Margin="16,8,16,0" Padding="8" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Image x:Name="PreviewImage" Grid.Column="0" MaxHeight="60" MaxWidth="60" Stretch="Uniform" Margin="0,0,8,0" Visibility="Collapsed"/>
                    <TextBlock x:Name="PreviewFileIcon" Grid.Column="0" Text="📄" FontSize="36" VerticalAlignment="Center" Margin="0,0,8,0" Visibility="Collapsed"/>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="PreviewFileName" Text="filename.jpg" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="PreviewFileSize" Text="120 KB" FontSize="11" Foreground="#65676B"/>
                    </StackPanel>
                    
                    <Button Grid.Column="2" Content="✕" Width="24" Height="24" Style="{StaticResource IconButtonStyle}" Foreground="#65676B" Click="CancelPreview_Click"/>
                </Grid>
            </Border>
            
            <!-- Input Row -->
            <Grid Margin="16,8,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Attachments -->
                    <ColumnDefinition Width="*"/>    <!-- TextBox -->
                    <ColumnDefinition Width="Auto"/> <!-- Send/Emoji -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Bottom">
                    <Button x:Name="AttachImageButton" Content="🖼️" ToolTip="Gửi Ảnh" Style="{StaticResource IconButtonStyle}" Click="AttachImageButton_Click"/>
                    <Button x:Name="AttachFileButton" Content="📎" ToolTip="Gửi File" Style="{StaticResource IconButtonStyle}" Click="AttachFileButton_Click"/>
                    <Button x:Name="StickerButton" Content="🌟" ToolTip="Nhãn dán" Style="{StaticResource IconButtonStyle}" Click="StickerButton_Click"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#F0F2F5" CornerRadius="18" Padding="12,6,12,6" MinHeight="36">
                    <TextBox x:Name="MessageInputBox" KeyDown="MessageInputBox_KeyDown" TextChanged="MessageInputBox_TextChanged"
                             TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="100" VerticalScrollBarVisibility="Auto"
                             BorderThickness="0" Background="Transparent" FontSize="14"
                             VerticalContentAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Bottom">
                    <Button x:Name="EmojiButton" Content="😊" ToolTip="Emoji" Style="{StaticResource IconButtonStyle}" Click="EmojiButton_Click" Margin="0,0,8,0"/>
                    <Button x:Name="SendButton" Content="➤" IsEnabled="False" Style="{StaticResource SendButtonStyle}" Width="40" Height="40" Padding="0" Click="SendButton_Click"/>
                </StackPanel>
            </Grid>
            
            <!-- Emoji Popup -->
            <Popup x:Name="EmojiPopup" PlacementTarget="{Binding ElementName=EmojiButton}" Placement="Top" StaysOpen="False" AllowsTransparency="True">
                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,10" Width="260" Height="220">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="EmojiItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}" Click="Emoji_Selected" Style="{StaticResource IconButtonStyle}" Margin="2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>
            
            <!-- Sticker Popup -->
            <Popup x:Name="StickerPopup" PlacementTarget="{Binding ElementName=StickerButton}" Placement="Top" StaysOpen="False" AllowsTransparency="True">
                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,10" Width="260" Height="220">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                    </Border.Effect>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="StickerItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="Sticker_Selected" Tag="{Binding}" Style="{StaticResource IconButtonStyle}" Margin="4" Width="60" Height="60">
                                        <Image Source="{Binding}" Stretch="Uniform"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>

        </StackPanel>
    </Grid>
</Window>
